# Atrium tracing / observability configuration.
# Copy to `.env` and adjust. These are standard OpenTelemetry env vars, read
# natively by the OTLP exporter; Atrium only fills in defaults when unset.

# OTLP/HTTP traces endpoint. For local Phoenix (docker compose up -d phoenix):
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces

# IMPORTANT (cross-container): GPU inference sandboxes run with NetworkMode.INTERNAL
# (WAN blocked; only 127/8 and 10/8 reachable). `localhost` inside a sandbox is
# NOT the host. For the in-sandbox bridge to reach Phoenix, set this to a
# host-local / control-plane LAN address reachable from the container, e.g.:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://10.0.0.1:6006/v1/traces
#   (or the docker host-gateway address, e.g. http://host.docker.internal:6006/v1/traces)

# Resource attributes attached to every span (shown/grouped in Phoenix).
OTEL_RESOURCE_ATTRIBUTES=service.namespace=atrium,deployment.environment=local

# Optional exporter headers (e.g. auth for a hosted collector):
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20<token>

# Kill switch: set to 1 to disable tracing entirely (no exporter, no connection).
# ATRIUM_TRACING_DISABLED=1
